NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Clave para cifrar la URL secreta del feed iCal (roster_connections.ical_url_encrypted).
# AES-256-GCM: 32 bytes en base64. Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# CRITICO: debe ser la MISMA en todos los entornos (local y Vercel) y estable en el
# tiempo. Si se pierde o cambia, las URLs cifradas ya guardadas quedan irrecuperables.
ICAL_ENCRYPTION_KEY=
